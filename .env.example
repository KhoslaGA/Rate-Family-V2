# Rate Family V2 — environment template
# Copy to app/.env.local for local dev. Backend needs no env in mock mode.

# ── Frontend → backend seam ──────────────────────────────────────────────
# Points the Next app's API client at the mock backend. Swap to the real
# API URL at cutover; nothing else changes.
NEXT_PUBLIC_API_BASE=http://localhost:3001

# ── Sanity (CMS) ─────────────────────────────────────────────────────────
# Required for the blog / editorial surfaces and /rss.xml to build. In the
# sandbox these are absent (that's why a bare `next build` stops at page
# data collection); on your machine / Vercel they resolve.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# ── Optional: analytics / email — fill when wiring those surfaces ─────────
# RESEND_API_KEY=
# NEXT_PUBLIC_SITE_URL=https://toprates.ca
